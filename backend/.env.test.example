# Copy to .env.test for running the backend test suite (`npm test`).
# Never commit the real .env.test (already gitignored via .env* at the
# repo root). Point this at a dedicated TEST Supabase project — never
# the dev/staging/prod one — since the test suite creates and deletes
# real auth users, tenants, and rows via the service_role key.

# Test project credentials. setupEnv.ts maps these onto the standard
# SUPABASE_URL/SUPABASE_SERVICE_ROLE_KEY vars the app itself reads, so
# the app-under-test and the fixtures helpers talk to the same project.
SUPABASE_URL_TEST=
SUPABASE_SERVICE_ROLE_KEY_TEST=

# Test project's JWT secret (Project Settings > API > JWT Settings >
# Legacy JWT Secret) — used to sign test JWTs locally in
# src/test/helpers.ts. Requires the project to have the legacy HS256
# shared-secret JWT signing enabled (not the newer asymmetric keys).
SUPABASE_JWT_SECRET=
