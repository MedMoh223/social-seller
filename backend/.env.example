# Copy to .env for local dev. Never commit the real .env (already gitignored
# at the repo root via .env*). Set the real values as Railway project env
# vars in production/staging — never in code.

NODE_ENV=development
PORT=3000

# Comma-separated list of allowed origins for CORS (Expo dev server URL,
# any web admin origin). No wildcard "*" in production.
CORS_ALLOWED_ORIGINS=http://localhost:8081

# Supabase project (service_role key bypasses RLS — backend-only secret).
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=

# This service's own public HTTPS URL (Railway domain, or an ngrok
# tunnel for local dev) — must exactly match the redirect_uri registered
# with Meta/TikTok.
BACKEND_PUBLIC_URL=http://localhost:3000

# AES-256-GCM key for encrypting social_connections tokens at rest.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('base64'))"
TOKEN_ENCRYPTION_KEY=

# --- Meta (WhatsApp Cloud API + Facebook Messenger Platform) — required
# once the Meta integration (US-06/US-07) is wired up. ---
META_APP_ID=
META_APP_SECRET=
WHATSAPP_WEBHOOK_VERIFY_TOKEN=
FACEBOOK_WEBHOOK_VERIFY_TOKEN=

# --- TikTok Business Messaging — required once US-08 is wired up. ---
TIKTOK_CLIENT_KEY=
TIKTOK_CLIENT_SECRET=
